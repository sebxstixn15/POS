<Window x:Class="Waldwunderverwaltung.Views.NeuesWaldwunderDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:models="clr-namespace:Waldwunderverwaltung.Models"
        Title="Neues Waldwunder anlegen"
        Width="540" Height="620"
        MinWidth="480" MinHeight="540"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip"
        Background="#F5F7FA">

    <Window.Resources>
        <Style TargetType="Label">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#2D4A3E"/>
            <Setter Property="Margin" Value="0,6,0,2"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="BorderBrush" Value="#B0C4B8"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="BorderBrush" Value="#B0C4B8"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
        <Style x:Key="ActionButton" TargetType="Button">
            <Setter Property="Padding" Value="14,7"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="5"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0" Text="🌲 Neues Waldwunder" FontSize="18" FontWeight="Bold"
                   Foreground="#1B4332" Margin="0,0,0,12"/>

        <!-- Form Fields -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <Label Content="Name *"/>
                <TextBox x:Name="txtName" MaxLength="200"/>

                <Label Content="Beschreibung *"/>
                <TextBox x:Name="txtDescription" Height="80" TextWrapping="Wrap"
                         AcceptsReturn="True" VerticalScrollBarVisibility="Auto"/>

                <Label Content="Bundesland *"/>
                <ComboBox x:Name="cmbProvince"/>

                <Label Content="Art *"/>
                <TextBox x:Name="txtType" MaxLength="100"/>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <Label Content="Latitude *"/>
                        <TextBox x:Name="txtLatitude" MaxLength="20"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <Label Content="Longitude *"/>
                        <TextBox x:Name="txtLongitude" MaxLength="20"/>
                    </StackPanel>
                </Grid>

                <!-- Image Section -->
                <Separator Margin="0,12,0,8" Background="#C8D8C8"/>
                <Label Content="Bilder" FontSize="14"/>

                <WrapPanel Margin="0,0,0,6">
                    <Button x:Name="btnAddImages" Content="📂 Bilder hinzufügen"
                            Style="{StaticResource ActionButton}"
                            Background="#3A7D44" Foreground="White"
                            Click="BtnAddImages_Click" Margin="0,0,8,0"/>
                    <Button x:Name="btnRemoveImage" Content="🗑 Entfernen"
                            Style="{StaticResource ActionButton}"
                            Background="#C0392B" Foreground="White"
                            Click="BtnRemoveImage_Click"/>
                </WrapPanel>

                <Border BorderBrush="#B0C4B8" BorderThickness="1" CornerRadius="4" Background="White">
                    <ListBox x:Name="lstImages" Height="100"
                             BorderThickness="0" Background="Transparent"
                             SelectionMode="Single"/>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- Validation Message -->
        <TextBlock x:Name="txtValidation" Grid.Row="2"
                   Foreground="#C0392B" FontStyle="Italic"
                   TextWrapping="Wrap" Margin="0,8,0,0" Visibility="Collapsed"/>

        <!-- Buttons -->
        <WrapPanel Grid.Row="3" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Abbrechen" Style="{StaticResource ActionButton}"
                    Background="#95A5A6" Foreground="White"
                    Click="BtnCancel_Click" Margin="0,0,8,0"/>
            <Button Content="✔ Registrieren" Style="{StaticResource ActionButton}"
                    Background="#1B4332" Foreground="White"
                    Click="BtnRegistrieren_Click"/>
        </WrapPanel>
    </Grid>
</Window>

<Window x:Class="Waldwunderverwaltung.Views.WaldwunderDetailDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Waldwunder Details"
        Width="720" Height="560"
        MinWidth="500" MinHeight="400"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip"
        Background="#F5F7FA">

    <Window.Resources>
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#2D4A3E"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Margin" Value="0,6,0,1"/>
        </Style>
        <Style x:Key="FieldValue" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#333333"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock x:Name="txtTitle" Grid.Row="0"
                   FontSize="20" FontWeight="Bold" Foreground="#1B4332"
                   Margin="0,0,0,12" TextWrapping="Wrap"/>

        <!-- Info Grid -->
        <Border Grid.Row="1" Background="White" CornerRadius="8"
                BorderBrush="#C8D8C8" BorderThickness="1" Padding="14,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" MinWidth="100"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="Auto" MinWidth="100"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Style="{StaticResource FieldLabel}" Text="Beschreibung"/>
                <TextBlock x:Name="txtDescription" Grid.Row="0" Grid.Column="2" Grid.ColumnSpan="5"
                           Style="{StaticResource FieldValue}"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Style="{StaticResource FieldLabel}" Text="Bundesland"/>
                <TextBlock x:Name="txtProvince" Grid.Row="1" Grid.Column="2" Style="{StaticResource FieldValue}"/>

                <TextBlock Grid.Row="1" Grid.Column="4" Style="{StaticResource FieldLabel}" Text="Art"/>
                <TextBlock x:Name="txtType" Grid.Row="1" Grid.Column="6" Style="{StaticResource FieldValue}"/>

                <TextBlock Grid.Row="2" Grid.Column="0" Style="{StaticResource FieldLabel}" Text="Latitude"/>
                <TextBlock x:Name="txtLatitude" Grid.Row="2" Grid.Column="2" Style="{StaticResource FieldValue}"/>

                <TextBlock Grid.Row="2" Grid.Column="4" Style="{StaticResource FieldLabel}" Text="Longitude"/>
                <TextBlock x:Name="txtLongitude" Grid.Row="2" Grid.Column="6" Style="{StaticResource FieldValue}"/>

                <TextBlock Grid.Row="3" Grid.Column="0" Style="{StaticResource FieldLabel}" Text="ID"/>
                <TextBlock x:Name="txtId" Grid.Row="3" Grid.Column="2" Style="{StaticResource FieldValue}"/>
            </Grid>
        </Border>

        <!-- Images Section -->
        <Grid Grid.Row="2" Margin="0,12,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="🖼 Bilder" FontSize="14" FontWeight="SemiBold"
                       Foreground="#1B4332" Margin="0,0,0,8"/>

            <Border Grid.Row="1" Background="White" CornerRadius="8"
                    BorderBrush="#C8D8C8" BorderThickness="1">
                <ScrollViewer HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Disabled">
                    <WrapPanel x:Name="imagePanel" Margin="8" Orientation="Horizontal"/>
                </ScrollViewer>
            </Border>
        </Grid>

        <!-- Close Button -->
        <Button Grid.Row="3" Content="Schließen" HorizontalAlignment="Right"
                Margin="0,12,0,0" Click="BtnClose_Click"
                Padding="16,8" Background="#1B4332" Foreground="White"
                FontWeight="SemiBold" FontSize="13" BorderThickness="0">
            <Button.Template>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}" CornerRadius="5"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Button.Template>
        </Button>
    </Grid>
</Window>

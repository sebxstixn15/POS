<Window x:Class="Gomoku.StartDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Gomoku Start" Height="300" Width="350" WindowStartupLocation="CenterScreen">
    <StackPanel Margin="20">
        <TextBlock Text="Spielmodus wählen:" Margin="0,0,0,5" FontWeight="Bold"/>
        <ComboBox x:Name="ModeBox" SelectedIndex="0">
            <ComboBoxItem Content="Mensch vs. Mensch (Lokal)"/>
            <ComboBoxItem Content="Mensch vs. Computer"/>
            <ComboBoxItem Content="Netzwerk: Server starten"/>
            <ComboBoxItem Content="Netzwerk: Client beitreten"/>
        </ComboBox>

        <TextBlock Text="Spielfeldgröße:" Margin="0,0,0,5" FontWeight="Bold"/>
        <Slider x:Name="SizeSlider" Minimum="10" Maximum="25" Value="15" TickFrequency="1" IsSnapToTickEnabled="True"/>
        <TextBlock Text="{Binding ElementName=SizeSlider, Path=Value, StringFormat={}{0:0}x{0:0}}" HorizontalAlignment="Center" Margin="0,0,0,15"/>

        <Button Content="Spiel starten" Click="Start_Click" Height="40" Background="LightGreen" FontWeight="Bold"/>
    </StackPanel>
</Window>